+          // get next point
+          const x2 = lineCoords[j + 1][0];
+          const y2 = lineCoords[j + 1][1];
+
+          // determine which cells the endpoints are in
+          const cellX1 = Math.max(
+            Math.min(Math.floor((x1 - bbox[0]) / cellWidth), gridSizeX - 1),
